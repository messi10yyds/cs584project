<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.basic.backend.mapper.SymptomQuestionMapper">

    <select id="selectAll" resultType="com.basic.backend.entity.SymptomQuestion">
        SELECT id,
               question
        FROM symptom_questions
        ORDER BY id ASC
    </select>

</mapper>